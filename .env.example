# Local development only. Do not put production secrets in this file.
DATABASE_URL=postgresql://som:som@localhost:5432/som_seedtalent_capture
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=som-capture-dev
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
CAPTURE_ARTIFACT_ROOT=./captures
LOG_LEVEL=INFO

# Autonomous capture mode. Values below are examples only.
SEEDTALENT_BASE_URL=https://app.seedtalent.com
SEEDTALENT_PERMISSION_BASIS=seedtalent_contract_full_use
PERMISSION_MANIFEST_PATH=./config/permission_manifest.example.yaml
PLAYWRIGHT_AUTH_STATE_PATH=./.secrets/playwright/seedtalent-storage-state.json
CAPTURE_BOT_ACCOUNT_ALIAS=seedtalent-capture-bot
CREDENTIAL_PROVIDER=manual_storage_state
# Other possible credential providers: onepassword_cli, aws_secrets_manager, gcp_secret_manager, azure_key_vault, doppler, bitwarden_cli
AUTONOMOUS_CAPTURE_ENABLED=false
AUTONOMOUS_MAX_CONCURRENT_SESSIONS=1
AUTONOMOUS_RATE_LIMIT_DELAY_SECONDS=5
QUIZ_CAPTURE_MODE=capture_and_complete_on_capture_account
