# Local development only. Do not put production secrets in this file.
DATABASE_URL=postgresql://som:som@localhost:5432/som_seedtalent_capture
CAPTURE_ARTIFACT_ROOT=C:\dev\_capture_artifacts\learning_capture_pipeline
CAPTURE_SECRET_ROOT=C:\dev\_secrets\learning-capture-pipeline
LOG_LEVEL=INFO

# Autonomous capture mode. Values below are repo-safe examples only.
SEEDTALENT_BASE_URL=https://app.seedtalent.com
SEEDTALENT_PERMISSION_BASIS=seedtalent_contract_full_use
PERMISSION_MANIFEST_PATH=C:\dev\_secrets\learning-capture-pipeline\manifests\permission_manifest.yaml
PLAYWRIGHT_AUTH_STATE_PATH=C:\dev\_secrets\learning-capture-pipeline\playwright\storage-state.json
APPROVED_COURSES_PATH=C:\dev\_secrets\learning-capture-pipeline\inputs\approved_courses.yaml
AUTH_PREFLIGHT_SCREENSHOT_DIR=C:\dev\_capture_artifacts\learning_capture_pipeline\preflight
CAPTURE_BOT_ACCOUNT_ALIAS=seedtalent-capture-bot
CREDENTIAL_PROVIDER=manual_storage_state
# Other possible credential providers: onepassword_cli, aws_secrets_manager, gcp_secret_manager, azure_key_vault, doppler, bitwarden_cli
AUTONOMOUS_CAPTURE_ENABLED=false
AUTONOMOUS_MAX_CONCURRENT_SESSIONS=1
AUTONOMOUS_RATE_LIMIT_DELAY_SECONDS=5
QUIZ_CAPTURE_MODE=capture_and_complete_on_capture_account
# Object storage is deferred for the first live pilot; keep artifacts local-first.
